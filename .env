# ── Host user identity ─────────────────────────────────────────────────────────
# Must match the host user so bind-mounted files have consistent ownership.
# Run `make env` to auto-populate these from the current shell user.
USER_UID=1000
USER_GID=1000
USERNAME=rosdev

# ── Jetson L4T version ────────────────────────────────────────────────────────
# Check your JetPack version: `cat /etc/nv_tegra_release`
# Image tag is hardcoded in docker/Dockerfile — L4T_VERSION no longer used for the jazzy build.

# ── ROS networking ────────────────────────────────────────────────────────────
ROS_MASTER_URI=http://localhost:11311
ROS_HOSTNAME=localhost

# ── Compose project name (used as image/container prefix) ─────────────────────
COMPOSE_PROJECT_NAME=divi
