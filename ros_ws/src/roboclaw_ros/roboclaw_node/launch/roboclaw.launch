<?xml version="1.0"?>
<launch>

    <arg name="dev" default="/dev/ttyACM0"/>
    <arg name="baud" default="38400"/>
    <arg name="address" default="128"/>
    <arg name="max_speed" default="2.0"/>
    <arg name="ticks_per_rev" default="537.7"/>
    <arg name="wheel_diameter_m" default="0.1036"/>
    <arg name="track_width_m" default="0.273036"/>
    <arg name="cmd_frequency" default="20"/>

    <node pkg="roboclaw_node" type="roboclaw_node.py" name="roboclaw_node" output="screen">
        <param name="~dev" value="$(arg dev)"/>
        <param name="~baud" value="$(arg baud)"/>
        <param name="~address" value="$(arg address)"/>
        <param name="~max_speed" value="$(arg max_speed)"/>
        <param name="~ticks_per_rev" value="$(arg ticks_per_rev)"/>
        <param name="~wheel_diameter_m" value="$(arg wheel_diameter_m)"/>
        <param name="~track_width_m" value="$(arg track_width_m)"/>
        <param name="~cmd_frequency" value="$(arg cmd_frequency)"/>
    </node>

    <node pkg="diagnostic_aggregator" type="aggregator_node"
          name="diagnostic_aggregator">
        <rosparam command="load"
                  file="$(find roboclaw_node)/config/roboclaw_diag.yaml"/>
    </node>

</launch>
